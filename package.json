{
  "name": "hireops",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Enterprise ATS platform for the Kyndryl GCC POC.",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @hireops/db db:migrate",
    "db:test:setup": "pnpm --filter @hireops/db db:test:setup",
    "db:test:verify": "pnpm --filter @hireops/db db:test:verify",
    "db:test:verify-rls": "pnpm --filter @hireops/db db:test:verify-rls",
    "db:diagnose:hook": "pnpm --filter @hireops/db db:diagnose:hook",
    "db:lint:rls": "pnpm --filter @hireops/db db:lint:rls",
    "db:provision:dev-dek": "pnpm --filter @hireops/db db:provision:dev-dek",
    "db:seed:test-users": "pnpm --filter @hireops/db db:seed:test-users",
    "db:seed:demo-data": "pnpm --filter @hireops/db db:seed:demo-data",
    "db:seed:partner-demo": "pnpm --filter @hireops/db db:seed:partner-demo",
    "db:seed:candidate-demo": "pnpm --filter @hireops/db db:seed:candidate-demo",
    "db:groom:demo-data": "pnpm --filter @hireops/db db:groom:demo-data",
    "api:dev": "pnpm --filter @hireops/api dev",
    "api:start": "pnpm --filter @hireops/api start",
    "api:test": "pnpm --filter @hireops/api test",
    "test:gate": "pnpm --filter @hireops/notifications exec vitest run && pnpm --filter @hireops/agent-actions exec vitest run && pnpm --filter @hireops/api test:gate",
    "portal:dev": "pnpm --filter @hireops/internal-portal dev",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "9.18.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "22.10.5",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-storybook": "^10.3.6",
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  }
}
