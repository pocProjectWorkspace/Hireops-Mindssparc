# HireOps environment variables
# Copy this file to .env and fill in the values.
# Per-app .env files will live alongside their respective apps once
# product code lands. This root stub exists only as a placeholder.
#
# .env files are gitignored — never commit secrets.

# ============================================================
# Database (Supabase) — dual-connection pattern.
# Both URIs come from Supabase dashboard → Connect (top bar). Both pooler
# hosts are dual-stack IPv4+IPv6. Username is `postgres.<PROJECT_REF>`
# (with the dot — required by Supavisor). Replace [YOUR-PASSWORD] with
# the actual database password.
# ============================================================

# Transaction-mode pooler (port 6543) — runtime queries.
# Multiplexes connections; prepared statements are disabled in client.ts.
# Copy from: Supabase dashboard → Connect → Transaction pooler.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-REGION.pooler.supabase.com:6543/postgres"

# Session-mode pooler (port 5432) — migrations and long-running workers.
# Behaves like a direct connection (queues, supports prepared statements).
# Replaces the legacy direct host (db.<project>.supabase.co), which is
# IPv6-only on the free tier and fails on IPv4-only networks.
# Copy from: Supabase dashboard → Connect → Session pooler.
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ============================================================
# Supabase Auth & API
# ============================================================
# Project URL (Settings → API → Project URL)
SUPABASE_URL="https://PROJECT_REF.supabase.co"

# Anon key (public; safe to use client-side; from Settings → API)
SUPABASE_ANON_KEY="eyJ..."

# Service role key (NEVER ship to client; from Settings → API)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# JWT secret used for verifying tokens (Settings → API → JWT Settings).
# Legacy — apps/api now verifies via the project's JWKS endpoint
# (.well-known/jwks.json). Kept for backward compatibility with older tooling.
SUPABASE_JWT_SECRET="..."

# ============================================================
# Envelope encryption — local KEK
# ============================================================
# Master key-encryption key for the local KMS implementation. Used to wrap
# per-tenant DEKs in tenant_encryption_keys. 32 random bytes, hex-encoded
# (64 hex characters).
#
# Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Production replaces this with AWS KMS — switch by setting
# KMS_PROVIDER=aws and AWS_KMS_KEY_ARN to the master key ARN. The local
# implementation throws if KMS_PROVIDER is anything other than 'local' or
# 'aws'.
SUPABASE_KEK_SECRET="replace-with-64-hex-chars"

# Optional. Defaults to 'local'. Set to 'aws' once AwsKmsClient is
# implemented (currently a throwing stub).
# KMS_PROVIDER="local"
